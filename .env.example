# ============================================================
# Banco Ágil — Variáveis de Ambiente
# ============================================================
# Copie para .env e preencha com suas credenciais:
#   cp .env.example .env
# ============================================================

# ---------- App ----------
# Ambiente: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------- LLM Provider ----------
# Opções: "google" (padrão, free tier) ou "openai"
LLM_PROVIDER=google

# ---------- Google Gemini ----------
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Modelos (padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ---------- OpenAI (alternativo) ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-nano

# ---------- API Security ----------
# Chave para proteger o endpoint /api/v1/chat (obrigatória em produção)
# API_KEY=sua-chave-secreta-aqui

# ---------- CORS ----------
# Origens permitidas (separar por vírgula). Vazio = permite tudo (só em dev).
# CORS_ORIGINS=https://banco-agil.com,https://demo.banco-agil.com

# ---------- Request Timeout ----------
# Timeout máximo por request em segundos (padrão: 30)
# REQUEST_TIMEOUT=30

# ---------- Observabilidade ----------
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
