# ============================================================
# Banco Ágil — Variáveis de Ambiente
# ============================================================
# Copie para .env e preencha com suas credenciais:
#   cp .env.example .env
# ============================================================

# ---------- LLM Provider ----------
# Opções: "google" (padrão, free tier) ou "openai"
LLM_PROVIDER=google

# ---------- Google Gemini ----------
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Modelos (padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ---------- OpenAI (alternativo) ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-nano

# ---------- App ----------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
